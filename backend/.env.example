# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL — Supabase
DATABASE_URL=connection_string_here

# JWT — generated secure secrets
JWT_SECRET=eullafied_jwt_secret_key_2025_super_secure_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=eullafied_refresh_secret_key_2025_super_secure_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# Mail (leave empty for now)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
